   "source": [
    "# 3. FOM solve\n",
    "fds = FrequencyDomainSolver(geo, order=3)\n",
    "fds.assemble_matrices(nportmodes=1)\n",
    "fds.solve(0.1, 2, 100, store_snapshots=True)\n",
    "\n",
    "# 4. Quick comparison plots - just pass the objects!\n",
    "frequencies = np.linspace(0.1, 2, 1000) * 1e9\n",
    "plot_z_comparison([fds], frequencies=frequencies)\n",
    "plot_s_comparison([fds], frequencies=frequencies)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e555ce40-aefa-4c30-8bf1-fe67f9074da3",
   "metadata": {},
   "outputs": [],
