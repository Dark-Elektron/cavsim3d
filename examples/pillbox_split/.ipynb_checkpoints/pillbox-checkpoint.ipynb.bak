   "source": [
    "# Pillbox Analysis\n",
    "\n",
    "This notebook demonstrates a complete rectangular waveguide analysis workflow:\n",
    "\n",
    "1. Geometry creation\n",
    "2. Frequency-domain analysis\n",
    "3. Model order reduction\n",
    "4. Comparison with analytical solution"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "235fd022ed9a46ce",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-02-26T13:19:20.759840Z",
     "start_time": "2026-02-26T13:19:18.152249Z"
    }
   },
   "outputs": [],
   "source": [
    "from utils.visualization import *\n",
    "from geometry.importers import STEPImporter, TESLACavity, GMSHImporter\n",
    "from solvers.frequency_domain import FrequencyDomainSolver\n",
    "from rom.reduction import ModelOrderReduction\n",
    "from analytical.circular_waveguide import CWGAnalytical\n",
    "from ngsolve.webgui import Draw # must import Draw, otherwise may run into problems showing mesh\n",
    "from utils.visualization import (\n",
    "    plot_z_comparison, \n",
    "    plot_s_comparison, \n",
    "    plot_all_parameters,\n",
    "    plot_eigenfrequencies,\n",
    "    ParameterPlotter,\n",
    "    EigenfrequencyPlotter\n",
    ")\n",
    "%matplotlib inline\n",
    "plt.rcParams['figure.dpi'] = 100"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "3946fc78eff70e0",
   "metadata": {},
   "source": [
    "## 1. Define Geometry\n",
    "\n",
    "Create a rectangular waveguide with specified dimensions and mesh parameters."
   ]
  },
  {
   "cell_type": "code",
