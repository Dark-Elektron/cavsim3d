   "source": [
    "# 1. Load and prepare geometry\n",
    "# geo = STEPImporter(r\"./tesla.step\", auto_build=False)\n",
    "# geo = TESLACavity(r'C:\\Users\\Soske\\Documents\\git_projects\\cavsim2d\\thesis\\tesla9cell.geo')\n",
    "geo = GMSHImporter(r'C:\\Users\\Soske\\Documents\\git_projects\\cavsim3d\\examples\\pillbox_geo\\cavities\\Cavities\\pillbox\\geometry\\geodata.geo', revolve=True)\n",
    "geo.save_step(r\"./pillbox.step\")\n",
    "# geo.add_splitting_plane_at_x(0.0)\n",
    "# geo.split()\n",
    "\n",
    "# geo.show_split_preview()\n",
    "geo.build()\n",
    "# geo.name_solids()\n",
    "\n",
    "geo.generate_mesh(maxh=100) # after naming solids, must generate mesh but avoid rebuilding"
   ]
  },
