   "source": [
    "# Rectangular Waveguide Analysis\n",
    "\n",
    "This notebook demonstrates a complete rectangular waveguide analysis workflow:\n",
    "\n",
    "1. Geometry creation\n",
    "2. Frequency-domain analysis\n",
    "3. Model order reduction\n",
    "4. Comparison with analytical solution"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "235fd022ed9a46ce",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-02-24T09:58:47.406891Z",
     "start_time": "2026-02-24T09:58:46.460468Z"
    }
   },
   "outputs": [],
   "source": [
    "from utils.visualization import *\n",
    "from geometry.primitives import RectangularWaveguide\n",
    "from solvers.frequency_domain import FrequencyDomainSolver\n",
    "from rom.reduction import ModelOrderReduction\n",
    "from analytical.rectangular_waveguide import RWGAnalytical\n",
    "from ngsolve.webgui import Draw # must import Draw, otherwise may run into problems showing mesh\n",
    "\n",
    "%matplotlib inline\n",
    "plt.rcParams['figure.dpi'] = 100"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "149ce933-6e7f-4597-8dcb-3121049fbd8b",
   "metadata": {},
   "outputs": [],
   "source": [
    "# %%time\n",
    "# %%timeit -n 3 -r 5\n",
    "# %time modes, basis = solver.solve(nmodes=3)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "3946fc78eff70e0",
   "metadata": {},
   "source": [
    "## 1. Define Geometry\n",
    "\n",
    "Create a rectangular waveguide with specified dimensions and mesh parameters."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "ac644f5124b0a9e7",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-02-24T09:58:47.484316Z",
     "start_time": "2026-02-24T09:58:47.417006Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Geometry saved to: rectangular_waveguide.step\n",
      "Dimensions: a=100mm, b=50mm, L=200mm\n",
      "Cutoff frequency (TE10): 1.499 GHz\n",
      "Mesh DOFs: ~48 vertices\n"
     ]
    },
    {
     "data": {
      "application/vnd.jupyter.widget-view+json": {
       "model_id": "5590835ce65e42ae9dc479b11f1d91d1",
       "version_major": 2,
       "version_minor": 0
      },
      "text/plain": [
       "WebGuiWidget(layout=Layout(height='50vh', width='100%'), value={'gui_settings': {}, 'ngsolve_version': '6.2.25…"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Waveguide parameters\n",
    "a = 100e-3  # Width: 100 mm\n",
    "L = 200e-3  # Length: 200 mm\n",
    "maxh = 0.04  # Mesh size\n",
    "\n",
    "# Create waveguide geometry\n",
    "rwg = RectangularWaveguide(a=a, L=L, maxh=maxh)\n",
    "# save step file\n",
    "rwg.save_step(r\"./rectangular_waveguide.step\")\n",
    "\n",
    "print(f\"Dimensions: a={a * 1e3:.0f}mm, b={rwg.b * 1e3:.0f}mm, L={L * 1e3:.0f}mm\")\n",
    "print(f\"Cutoff frequency (TE10): {rwg.cutoff_frequency_TE10 / 1e9:.3f} GHz\")\n",
    "print(f\"Mesh DOFs: ~{rwg.mesh.nv} vertices\")\n",
    "\n",
    "rwg.show('mesh')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c36e0506e37f6b1b",
   "metadata": {},
   "source": [
