   ],
   "source": [
    "fig, ax = plot_eigenfrequencies([fds, rom], analytical=analytical,\n",
    "                      labels=['FOM', 'ROM'], n_modes=50)\n",
    "ax.set_ylim(1, 5)\n",
    "ax.set_xlim(1, 5)"
   ]
  },
