    "# After ROM is working...\n",
    "from rom.reduction import ModelOrderReduction\n",
    "\n",
    "rom = ModelOrderReduction(fds)\n",
    "rom.reduce(max_rank=30, tol=1e-6)\n",
    "rom.solve(0.1, 1.5, 1000)\n",
    "\n",
    "# Compare all three\n",
